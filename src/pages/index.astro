---
import '../styles/global.css';

const title = "Félix Corcoran | Full Stack & AI Automation";
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body class="bg-neutral-950 text-white selection:bg-blue-500/30 font-sans">
        
        <main>
            <section class="relative min-h-screen flex items-center justify-center bg-[#050505] px-6 overflow-hidden">
                <div class="absolute inset-0 -z-10 overflow-hidden">
                    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-blue-600/15 blur-[120px] animate-pulse"></div>
                    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-indigo-600/15 blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[30%] h-[30%] rounded-full bg-blue-400/5 blur-[100px]"></div>
                    
                    <div class="absolute left-10 top-1/2 -translate-y-1/2 hidden lg:block">
                        <span class="text-[10px] font-mono uppercase tracking-[1em] text-neutral-800 [writing-mode:vertical-lr]">
                            Logic • Design • Intelligence • 2026
                        </span>
                    </div>
                </div>

                <div class="max-w-7xl w-full">
                    <div class="flex flex-col gap-12">
                        <div class="flex items-center gap-4 animate-fade-in">
                            <div class="flex items-center gap-2 px-3 py-1 rounded-full border border-blue-500/20 bg-blue-500/5 backdrop-blur-md">
                                <span class="relative flex h-2 w-2">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
                                </span>
                                <span class="text-[9px] uppercase tracking-[0.2em] font-bold text-blue-400">Remote Ready</span>
                            </div>
                            <span class="text-[9px] uppercase tracking-[0.4em] text-neutral-600 font-medium">Bilingual ES/EN</span>
                        </div>

                        <div class="relative">
                            <h1 class="text-[16vw] lg:text-[13rem] font-black leading-[0.8] tracking-tighter text-white px-2 cursor-default">
                                <span class="inline-block transition-all duration-500 hover:blur-[25px] hover:opacity-30">FÉLIX</span> <br/>
                                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-500 to-white/90 italic pr-8 inline-block transition-all duration-500 hover:blur-[25px] hover:opacity-60">CORCORAN</span>
                            </h1>

                            <div class="mt-8 flex flex-col md:flex-row md:items-end gap-6">
                                <p class="text-3xl md:text-5xl font-extralight text-neutral-400 leading-none lowercase tracking-tighter">
                                    Desarrollador <span class="text-white italic">full stack</span> & <br class="hidden md:block"/> especialista en <span class="text-blue-500 font-normal">ia</span>.
                                </p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mt-10">
                            <div class="lg:col-span-7">
                                <p class="text-xl md:text-2xl font-light text-neutral-400 leading-snug">
                                    Titulado en <span class="text-white font-medium underline decoration-blue-500/30 underline-offset-8">DAW</span>. 
                                    Construyo arquitecturas <span class="text-white">MVC</span> robustas y orquesto flujos de trabajo inteligentes mediante <span class="text-indigo-400 font-mono">n8n</span> para escalar el potencial de productos digitales.
                                </p>
                            </div>
                            
                            <div class="lg:col-span-5 flex flex-col justify-end gap-10">
                                <a href="#proyectos" class="group relative flex items-end gap-4 px-2">
                                    <div class="relative overflow-hidden pr-6"> 
                                        <span class="block text-4xl md:text-5xl font-black uppercase tracking-tighter text-white transition-transform duration-500 group-hover:-translate-y-full">Proyectos</span>
                                        <span class="absolute top-0 left-0 block text-4xl md:text-5xl font-black uppercase tracking-tighter text-blue-500 italic transition-transform duration-500 translate-y-full group-hover:translate-y-0">Proyectos</span>
                                    </div>
                                    <div class="mb-2 h-px w-0 bg-neutral-500 transition-all duration-500 group-hover:w-12 opacity-50 group-hover:opacity-100"></div>
                                </a>

                                <a href="/cv-felix-corcoran.pdf" target="_blank" class="group relative flex items-end gap-4">
                                    <div class="relative overflow-hidden">
                                        <span class="block text-4xl md:text-5xl font-black uppercase tracking-tighter text-neutral-500 transition-transform duration-500 group-hover:-translate-y-full">Currículum</span>
                                        <span class="absolute top-0 left-0 block text-4xl md:text-5xl font-black uppercase tracking-tighter text-indigo-400 transition-transform duration-500 translate-y-full group-hover:translate-y-0">Descargar</span>
                                    </div>
                                    <div class="mb-3 flex h-2 w-2">
                                        <span class="animate-ping absolute inline-flex h-2 w-2 rounded-full bg-blue-400 opacity-0 group-hover:opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-400 group-hover:bg-blue-500 transition-colors duration-500"></span>
                                    </div>
                                </a>
                            </div>
                        </div>

                        <div class="mt-20 pt-10 border-t border-white/5 flex flex-wrap gap-x-12 gap-y-6 opacity-20">
                            <span class="text-[10px] font-mono uppercase tracking-[0.5em]">PHP / Laravel</span>
                            <span class="text-[10px] font-mono uppercase tracking-[0.5em]">MySQL / Architecture</span>
                            <span class="text-[10px] font-mono uppercase tracking-[0.5em]">Tailwind CSS / Astro</span>
                            <span class="text-[10px] font-mono uppercase tracking-[0.5em]">AJAX / REST API</span>
                        </div>
                    </div>
                </div>
            </section>

            <section id="tech" class="py-24 md:py-40 px-6 bg-black overflow-hidden">
                <div class="max-w-7xl mx-auto">
                    
                    <div class="flex flex-col lg:grid lg:grid-cols-12 gap-y-32 lg:gap-x-12 xl:gap-x-20 items-start">
                        
                        <!-- 01 SOFTWARE ENGINEERING (Respetando tus animaciones) -->
                        <div class="w-full lg:col-span-7 group/section">
                            <div class="relative space-y-6 md:space-y-10">
                                <div class="flex items-center gap-6 text-blue-500 font-mono text-xs tracking-widest uppercase">
                                    <span>01</span>
                                    <div class="h-px flex-1 bg-blue-500/20"></div>
                                    <span>Backend & Architecture</span>
                                </div>
                                
                                <!-- Tu animación de Reveal original -->
                                <div class="relative overflow-hidden group/reveal py-2 cursor-default">
                                    <h3 class="text-5xl md:text-7xl xl:text-8xl font-bold text-white leading-none transition-transform duration-500 group-hover/reveal:-translate-y-[110%] tracking-tighter uppercase">
                                        SOFTWARE <br/> ENGINEERING
                                    </h3>
                                    <h3 class="text-5xl md:text-7xl xl:text-8xl font-bold leading-none absolute top-full left-0 transition-transform duration-500 group-hover/reveal:-translate-y-[110%] italic tracking-tighter uppercase">
                                        <span class="text-blue-500">SOFTWARE</span> <br/> 
                                        <span class="text-transparent" style="-webkit-text-stroke: 1px rgba(255,255,255,0.5);">ENGINEERING</span>
                                    </h3>
                                </div>
                                
                                <p class="text-neutral-500 text-xl md:text-2xl lg:text-2xl xl:text-2xl font-light leading-relaxed max-w-xl">
                                    Desarrollo de arquitecturas robustas y escalables bajo el patrón MVC, garantizando una lógica de servidor eficiente y una gestión de datos optimizada.
                                </p>

                                <!-- Tus Iconos con animaciones originales -->
                                <div class="flex flex-wrap gap-4 pt-4">
                                    {['php', 'laravel', 'java', 'mysql'].map((tech) => (
                                        <div class="group/tech relative flex flex-col items-center">
                                            <img src={`https://skillicons.dev/icons?i=${tech}`} 
                                                class="h-10 w-10 md:h-12 md:w-12 transition-all duration-300 grayscale-0 group-hover/section:grayscale group-hover/tech:grayscale-0 group-hover/tech:scale-110" 
                                                alt={tech} />
                                            <div class="absolute -bottom-2 w-0 h-px bg-blue-500 group-hover/tech:w-full transition-all duration-500"></div>
                                            <span class="absolute -bottom-8 text-[10px] font-mono text-blue-500 opacity-0 group-hover/tech:opacity-100 uppercase tracking-tighter">
                                                {tech}
                                            </span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </div>

                        <!-- 02 VISUAL FIDELITY (Tu código original tal cual) -->
                        <div class="w-full lg:col-span-5 flex flex-col justify-end group/section lg:pt-20 border-t border-white/5 pt-20 lg:border-none">                   
                            <div class="space-y-6 md:space-y-10 relative">
                                <div class="flex items-center gap-6 text-indigo-500 font-mono text-xs tracking-widest uppercase">
                                    <span>02</span>
                                    <div class="h-px flex-1 bg-indigo-500/20"></div>
                                    <span>Frontend & UI</span>
                                </div>
                                
                                <div class="relative overflow-hidden group/reveal py-2 cursor-default">
                                    <h3 class="text-5xl md:text-7xl font-bold text-white leading-none transition-transform duration-500 group-hover/reveal:-translate-y-[110%] tracking-tighter">
                                        VISUAL <br/> FIDELITY
                                    </h3>
                                    
                                    <h3 class="text-5xl md:text-7xl font-bold leading-none absolute top-full left-0 transition-transform duration-500 group-hover/reveal:-translate-y-[110%] italic tracking-tighter">
                                        <span class="text-indigo-400">VISUAL</span> <br/> 
                                        <span class="text-transparent" style="-webkit-text-stroke: 1px rgba(255,255,255,0.5);">FIDELITY</span>
                                    </h3>
                                </div>

                                <p class="text-neutral-500 text-xl md:text-2xl lg:text-md xl:text-xl font-light leading-snug max-w-2xl">
                                    Fidelidad total en la implementación de diseños UI/UX complejos, transformando prototipos estáticos en interfaces dinámicas, responsivas y con una experiencia de usuario fluida.
                                </p>
                                
                                <div class="flex flex-wrap gap-4 pt-4">
                                    {['astro', 'tailwind', 'js', 'jquery'].map((tech) => (
                                        <div class="group/tech relative flex flex-col items-center">
                                            <img src={`https://skillicons.dev/icons?i=${tech}`} 
                                                class="h-10 w-10 md:h-12 md:w-12 transition-all duration-300 grayscale-0 group-hover/section:grayscale group-hover/tech:grayscale-0 group-hover/tech:scale-110" 
                                                alt={tech} />
                                            <div class="absolute -bottom-2 w-0 h-px bg-indigo-500 group-hover/tech:w-full transition-all duration-500"></div>
                                            <span class="absolute -bottom-8 text-[10px] font-mono text-indigo-500 opacity-0 group-hover/tech:opacity-100 uppercase tracking-tighter">
                                                {tech}
                                            </span>
                                        </div>
                                    ))}
                                </div>
                            </div>
                        </div>

                        <div class="md:col-span-12 border-t border-white/5 pt-32 group/section">
                            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
                                <div class="lg:col-span-5 space-y-10">
                                    <div class="flex items-center gap-6 text-blue-400 font-mono text-xs tracking-widest uppercase">
                                        <span>03</span>
                                        <div class="h-px flex-1 bg-blue-400/20"></div>
                                        <span>AI Orchestration</span>
                                    </div>
                                    
                                    <h3 class="text-[12rem] lg:text-[16rem] font-black leading-none text-transparent transition-all duration-700 select-none cursor-default
                                        [-webkit-text-stroke:4px_rgba(255,255,255,0.2)] 
                                        group-hover/section:text-white 
                                        group-hover/section:[-webkit-text-stroke:4px_#60a5fa]">
                                        n8n
                                    </h3>
                                </div>
                                
                                <div class="lg:col-span-7 flex flex-col justify-center space-y-12">
                                    <p class="text-3xl md:text-5xl text-white font-extralight leading-tight tracking-tighter">
                                        Automatización de procesos complejos mediante la orquestación de <span class="text-blue-400 italic font-normal">APIs de IA</span> y el procesamiento avanzado de datos en formato <span class="text-blue-400">JSON</span>.
                                    </p>
                                    
                                    <div class="flex flex-wrap gap-4 pt-4">
                                        {['ai', 'postman', 'docker', 'git'].map((tech) => (
                                            <div class="group/tech relative flex flex-col items-center">
                                                <img src={`https://skillicons.dev/icons?i=${tech}`} 
                                                    class="h-12 w-12 transition-all duration-300 grayscale-0 group-hover/section:grayscale group-hover/tech:grayscale-0 group-hover/tech:scale-110" 
                                                    alt={tech} />
                                                <div class="absolute -bottom-2 w-0 h-px bg-blue-400 group-hover/tech:w-full transition-all duration-500"></div>
                                                <span class="absolute -bottom-8 text-[10px] font-mono text-blue-400 opacity-0 group-hover/tech:opacity-100 uppercase tracking-tighter">
                                                    {tech}
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="md:col-span-12 border-t border-white/5 pt-32 group/section">
                            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-center">
                                
                                <div class="lg:col-span-5 flex justify-center lg:justify-start relative overflow-visible hidden lg:flex">
                                    <div class="relative -ml-40">
                                        <svg 
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="700"
                                            height="700"
                                            viewBox="0 0 100 100"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="text-indigo-500/10 animate-[spin_40s_linear_infinite] transition-colors duration-1000 group-hover/section:text-indigo-500/30"
                                        >
                                            <path d="
                                                M50 4
                                                L60 4
                                                L63 15
                                                L73 19
                                                L82 11
                                                L89 18
                                                L81 27
                                                L85 37
                                                L96 40
                                                L96 50
                                                L85 53
                                                L81 63
                                                L89 72
                                                L82 79
                                                L73 71
                                                L63 75
                                                L60 86
                                                L50 86
                                                L47 75
                                                L37 71
                                                L28 79
                                                L21 72
                                                L29 63
                                                L25 53
                                                L14 50
                                                L14 40
                                                L25 37
                                                L29 27
                                                L21 18
                                                L28 11
                                                L37 19
                                                L47 15
                                                Z
                                            " />

                                            <circle cx="55" cy="45" r="13"></circle>
                                        </svg>
                                    </div>
                                </div>

                                <div class="lg:col-span-7 flex flex-col lg:items-end lg:text-right space-y-10">
                                    <div class="flex items-center gap-6 text-indigo-500 font-mono text-xs tracking-widest uppercase w-full">
                                        <span>04</span>
                                        <div class="h-px flex-1 bg-indigo-500/20"></div>
                                        <span class="text-indigo-400">Continuous Learning</span>
                                    </div>
                                    
                                    <div class="cursor-default overflow-hidden">
                                        <h3 class="text-7xl md:text-[9rem] font-black leading-[0.8] uppercase tracking-tighter">
                                            <div class="relative block h-[0.9em] overflow-hidden">
                                                <span class="absolute inset-0 transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]
                                                    text-transparent [-webkit-text-stroke:2px_rgba(255,255,255,0.2)]
                                                    group-hover/section:translate-x-full
                                                    group-hover/section:opacity-0">
                                                    NEW
                                                </span>
                                                <span class="absolute inset-0 translate-x-[-120%] opacity-0
                                                    transition-all duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]
                                                    text-white-400
                                                    group-hover/section:translate-x-0
                                                    group-hover/section:opacity-100">
                                                    NEW
                                                </span>
                                            </div>
                                            <span class="block transition-all duration-500 text-white group-hover/section:text-indigo-400 group-hover/section:italic group-hover/section:translate-x-[-15px]">
                                                HORIZONS
                                            </span>
                                        </h3>
                                    </div>

                                    <p class="text-neutral-500 text-xl md:text-2xl font-light leading-relaxed max-w-lg">
                                        Ampliando mi stack con tecnologías modernas para construir interfaces reactivas, flujos de datos complejos y arquitecturas con tipado estricto.
                                    </p>

                                    <div class="flex flex-wrap gap-6 justify-center lg:justify-end">
                                        {[
                                            {id: 'react', name: 'React'}, 
                                            {id: 'nextjs', name: 'Next.js'}, 
                                            {id: 'ts', name: 'TypeScript'}, 
                                            {id: 'supabase', name: 'Supabase'}
                                        ].map((tech) => (
                                            <div class="group/tech relative flex flex-col items-center">
                                                <img 
                                                    src={`https://skillicons.dev/icons?i=${tech.id}`} 
                                                    class="h-12 w-12 transition-all duration-500 grayscale-0 group-hover/section:grayscale group-hover/tech:grayscale-0 group-hover/tech:scale-110" 
                                                    alt={tech.name} 
                                                />
                                                <div class="absolute -bottom-2 w-0 h-px bg-indigo-500 group-hover/tech:w-full transition-all duration-500"></div>
                                                <span class="absolute -bottom-8 text-[10px] font-mono text-indigo-400 opacity-0 group-hover/tech:opacity-100 uppercase tracking-widest whitespace-nowrap">
                                                    {tech.name}
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section id="proyectos" class="py-32 px-6 bg-[#050505]">
                <div class="max-w-7xl mx-auto">
                    <div class="flex flex-col mb-24 space-y-4 overflow-hidden">
                        <h2 id="projects-title" class="text-5xl md:text-[8rem] font-black text-white tracking-tighter uppercase italic leading-none will-change-transform transition-all duration-1000 opacity-0 translate-y-20">
                            Trabajos <span class="text-transparent" style="-webkit-text-stroke: 1px rgba(255,255,255,0.2);">Seleccionados</span>
                        </h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                        
                        <a href="https://kaloai.infinityfreeapp.com/?i=1" target="_blank" class="md:col-span-8 group relative overflow-hidden bg-neutral-900/40 border border-white/5 rounded-[2.5rem] block transition-all duration-700 hover:border-blue-500/50">
                            <div class="p-10 md:p-16 h-full flex flex-col justify-between transition-all duration-700 group-hover:blur-2xl group-hover:scale-95 group-hover:opacity-10">
                                <div>
                                    <span class="text-[10px] font-bold text-blue-400 uppercase tracking-widest block mb-6">Full Stack & IA</span>
                                    <h3 class="text-6xl md:text-7xl font-black text-white tracking-tighter uppercase mb-6">Kalo AI</h3>
                                    <p class="text-neutral-400 text-lg font-light leading-relaxed max-w-md">
                                        Plataforma nutricional avanzada con gestión de recetas mediante inteligencia artificial y sistema multi-rol.
                                    </p>
                                </div>
                            </div>
                            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-700">
                                <div class="text-center">
                                    <span class="text-7xl md:text-[6rem] font-black text-white uppercase tracking-tighter block leading-none">Explorar</span>
                                    <span class="text-2xl font-mono text-blue-500 uppercase tracking-[0.5em]">Plataforma IA</span>
                                </div>
                            </div>
                            <span class="absolute -bottom-10 -right-10 text-[18rem] font-black text-white/[0.02] select-none pointer-events-none">AI</span>
                        </a>

                        <a href="https://orianar1.sg-host.com/es/" target="_blank" class="md:col-span-4 group relative p-10 bg-neutral-900/40 border border-white/5 rounded-[2.5rem] overflow-hidden block transition-all duration-500 hover:bg-blue-600">
                            <div class="relative z-10 h-full flex flex-col transition-all duration-500 group-hover:-translate-y-full group-hover:opacity-0">
                                <span class="text-[10px] font-bold text-blue-400 uppercase tracking-widest block mb-6">Web Landing</span>
                                <h3 class="text-4xl font-black text-white uppercase tracking-tighter mb-4">Weebü Messenger</h3>
                                <p class="text-neutral-500 text-sm leading-relaxed mb-10">
                                    Desarrollo integral de plataforma web promocional con navegación fluida y fiel al diseño original.
                                </p>
                                <div class="flex flex-wrap gap-2 mt-auto">
                                    <span class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-[9px] text-white/60 uppercase font-bold">
                                        Diseño Funcional
                                    </span>
                                    <span class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-[9px] text-white/60 uppercase font-bold">
                                        Experiencia de Usuario
                                    </span>
                                </div>
                            </div>
                            <div class="absolute inset-0 flex flex-col items-center justify-center translate-y-full group-hover:translate-y-0 transition-all duration-500 p-10">
                                <div class="w-20 h-20 rounded-full border border-white/20 flex items-center justify-center mb-4 bg-white/10 backdrop-blur-md">
                                    <span class="text-white text-3xl">↗</span>
                                </div>
                                <span class="text-2xl font-black text-white uppercase tracking-tighter">Visitar Web</span>
                            </div>
                        </a>

                        <div class="md:col-span-12 p-10 md:p-20 bg-neutral-900/20 border border-white/5 rounded-[3rem]">
                            
                            <div class="flex flex-col md:flex-row md:items-end justify-between mb-20 border-b border-white/5 pb-10">
                                <div>
                                    <span class="text-[10px] font-bold text-blue-400 uppercase tracking-widest block mb-4">
                                        Galería Freelance
                                    </span>

                                    <h3 class="text-5xl md:text-6xl font-black text-white uppercase tracking-tighter">
                                        Proyectos Realizados
                                    </h3>
                                </div>

                                <p class="text-neutral-500 font-mono text-xs uppercase tracking-widest italic mb-2">
                                    Desarrollo de Soluciones a Medida
                                </p>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                                {[
                                    { name: "MBH Builders", url: "https://mbhbuilders.es/inicio.html", cat: "Construcción" },
                                    { name: "Pilar Peluquería", url: "https://pilarpeluqueria.com/inicio.html", cat: "Peluquería" },
                                    { name: "Reformas Paola", url: "https://reformasymantenimientospaola.com/inicio", cat: "Reformas" },
                                    { name: "Ávila Secretaria Online", url: "https://avilasecretariaonline.com/inicio.html", cat: "Servicios" },
                                    { name: "Susana Floria Nails", url: "https://susanaflorianails.com/sobrenosotros.html", cat: "Estética" },
                                    { name: "Construcciones Omega", url: "https://construccionesyserviciosomega.com/inicio", cat: "Arquitectura" }
                                ].map((site, index) => (

                                    <a 
                                        href={site.url}
                                        target="_blank"
                                        class="group relative h-56 rounded-[2rem] overflow-hidden border border-white/5 bg-[#080808] block isolate"
                                    >
                                        <div class="absolute inset-0 bg-gradient-to-br from-blue-500/0 via-transparent to-indigo-500/0 group-hover:from-blue-500/20 group-hover:to-indigo-500/20 transition-all duration-1000"></div>
