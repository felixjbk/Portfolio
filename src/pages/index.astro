<style is:global>
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, sans-serif; }

    #stack-title { will-change: transform, opacity; }

    @keyframes reveal {
        0% { transform: translateY(50px); opacity: 0; filter: blur(20px); }
        100% { transform: translateY(0); opacity: 1; filter: blur(0); }
    }
    h1 { animation: reveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
    
    @keyframes fade-in {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    .animate-fade-in { animation: fade-in 2s ease-out forwards; }

    .hover\:!grayscale-0:hover { filter: grayscale(0) !important; }

    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: rgba(0,0,0,0.05); }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.2); border-radius: 10px; }
</style>

<script>
    const stackTitle = document.querySelector('#stack-title') as HTMLElement;
    const projectsTitle = document.querySelector('#projects-title') as HTMLElement;
    
    const handleScroll = () => {
        if (stackTitle) {
            const rectStack = stackTitle.getBoundingClientRect();
            const windowHeight = window.innerHeight;
            const scrollPercentStack = Math.min(Math.max((windowHeight - rectStack.top) / (windowHeight * 0.9), 0), 1);
            stackTitle.style.transform = `translateX(${(1 - scrollPercentStack) * -80}%)`;
            stackTitle.style.opacity = scrollPercentStack.toString();
        }
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting && projectsTitle) {

                projectsTitle.classList.remove('opacity-0', 'translate-y-20');
                projectsTitle.classList.add('opacity-100', 'translate-y-0');
            }
        });
    }, { threshold: 0.2 });

    if (projectsTitle) observer.observe(projectsTitle);

    window.addEventListener('scroll', handleScroll);
    handleScroll();

    const form = document.getElementById('contact-form');
    const btnText = document.getElementById('btn-text');
    const successMsg = document.getElementById('success-msg');
    const submitBtn = document.getElementById('submit-btn');

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Cambio de estado visual (Loading)
        btnText.innerText = "DEPLOYING...";
        submitBtn.style.pointerEvents = "none";
        submitBtn.style.opacity = "0.5";

        const formData = new FormData(form);
        
        try {
            const response = await fetch('/api/send-email', {
                method: 'POST',
                body: formData,
            });

            if (response.ok) {
                // Éxito
                form.reset();
                btnText.innerText = "DEPLOYED";
                successMsg.classList.remove('hidden');
                setTimeout(() => {
                    successMsg.classList.add('hidden');
                    btnText.innerText = "PUSH TO PRODUCTION";
                    submitBtn.style.pointerEvents = "auto";
                    submitBtn.style.opacity = "1";
                }, 5000);
            } else {
                btnText.innerText = "ERROR - TRY AGAIN";
            }
        } catch (error) {
            btnText.innerText = "CONNECTION FAILED";
        }
    });
</script>